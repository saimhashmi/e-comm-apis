{
	"openapi": "3.0.4",
	"info": {
		"title": "e-comm apis",
		"description": "APIs for E-commerce web app",
		"version": "1.0.0"
	},
	"servers": [
		{
			"url": "http://localhost:3000/"
		}
	],
	"tags": [
		{
			"name": "Users",
			"description": "User login and register APIs"
		},
		{
			"name": "Products",
			"description": "Secure Products APIs endpoint for CRUD operations"
		},
		{
			"name": "Cart",
			"description": "Shopping cart management APIs"
		}
	],
	"components": {
		"securitySchema": {
			"CookieAuth": {
				"type": "apiKey",
				"in": "cookie",
				"name": "jwtToken"
			}
		}
	},
	"paths": {
		"/api/users/login": {
			"post": {
				"tags": ["Users"],
				"summary": "login",
				"description": "User Login",
				"security": [],
				"requestBody": {
					"description": "User Credentials",
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"type": "object",
								"properties": {
									"email": {
										"type": "string"
									},
									"password": {
										"type": "string"
									}
								}
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "User logged in successfully"
					},
					"401": {
						"description": "Invalid email or password"
					}
				}
			}
		},
		"/api/users/register": {
			"post": {
				"tags": ["Users"],
				"summary": "Register",
				"description": "Register New User",
				"security": [],
				"requestBody": {
					"description": "User Information",
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"type": "object",
								"properties": {
									"name": {
										"type": "string"
									},
									"email": {
										"type": "string"
									},
									"password": {
										"type": "string"
									},
									"type": {
										"type": "string"
									}
								}
							}
						}
					}
				},
				"responses": {
					"201": {
						"description": "New user added successfully"
					}
				}
			}
		},
		"/api/products": {
			"get": {
				"tags": ["Products"],
				"summary": "Get Products List",
				"description": "Get all products",
				"security": [
					{
						"CookieAuth": []
					}
				],
				"responses": {
					"200": {
						"description": "products listed below"
					},
					"404": {
						"description": "No products to list"
					}
				}
			},
			"post": {
				"tags": ["Products"],
				"summary": "Add Product",
				"description": "Add a new product with image",
				"security": [
					{
						"CookieAuth": []
					}
				],
				"requestBody": {
					"description": "Product Information",
					"required": true,
					"content": {
						"multipart/form-data": {
							"schema": {
								"type": "object",
								"properties": {
									"name": {
										"type": "string",
										"description": "Product name"
									},
									"price": {
										"type": "number",
										"description": "Product price (must be positive)"
									},
									"category": {
										"type": "string",
										"description": "Product category"
									},
									"desc": {
										"type": "string",
										"description": "Product description"
									},
									"sizes": {
										"type": "string",
										"description": "Available sizes (comma-separated, e.g., 'S,M,L')"
									},
									"imageUrl": {
										"type": "string",
										"format": "binary",
										"description": "Product image file"
									}
								}
							}
						}
					}
				},
				"responses": {
					"201": {
						"description": "Product added successfully"
					},
					"400": {
						"description": "Bad request"
					}
				}
			}
		},

		"/api/products/{id}": {
			"get": {
				"tags": ["Products"],
				"summary": "Get Single Product",
				"description": "Get a product by ID",
				"security": [
					{
						"CookieAuth": []
					}
				],
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "integer"
						},
						"description": "Product ID"
					}
				],
				"responses": {
					"200": {
						"description": "Product found"
					},
					"404": {
						"description": "Product not found"
					}
				}
			}
		},
		"/api/products/filter": {
			"get": {
				"tags": ["Products"],
				"summary": "Filter Products",
				"description": "Filter products by price range and category",
				"security": [
					{
						"CookieAuth": []
					}
				],
				"parameters": [
					{
						"name": "minPrice",
						"in": "query",
						"schema": {
							"type": "number"
						},
						"description": "Minimum price"
					},
					{
						"name": "maxPrice",
						"in": "query",
						"schema": {
							"type": "number"
						},
						"description": "Maximum price"
					},
					{
						"name": "category",
						"in": "query",
						"schema": {
							"type": "string"
						},
						"description": "Product category"
					}
				],
				"responses": {
					"200": {
						"description": "Filtered products list"
					},
					"404": {
						"description": "No products found"
					}
				}
			}
		},
		"/api/products/{id}/rate": {
			"post": {
				"tags": ["Products"],
				"summary": "Rate Product",
				"description": "Add or update product rating",
				"security": [
					{
						"CookieAuth": []
					}
				],
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "integer"
						},
						"description": "Product ID"
					}
				],
				"requestBody": {
					"description": "Rating Information",
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"type": "object",
								"properties": {
									"rating": {
										"type": "number",
										"description": "Rating value (e.g., 4.5)"
									}
								},
								"required": ["rating"]
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "Product rated successfully"
					},
					"400": {
						"description": "Bad request"
					},
					"404": {
						"description": "User or product not found"
					}
				}
			}
		},

		"/api/cartItems": {
			"get": {
				"tags": ["Cart"],
				"summary": "Get Cart Items",
				"description": "Get all items in user's cart",
				"security": [
					{
						"CookieAuth": []
					}
				],
				"responses": {
					"200": {
						"description": "Items currently in cart"
					}
				}
			},
			"post": {
				"tags": ["Cart"],
				"summary": "Add to Cart",
				"description": "Add product to cart",
				"security": [
					{
						"CookieAuth": []
					}
				],
				"requestBody": {
					"description": "Product and quantity information",
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"type": "object",
								"properties": {
									"productID": {
										"type": "string",
										"description": "Product ID"
									},
									"quantity": {
										"type": "integer",
										"description": "Quantity (must be > 1)"
									}
								},
								"required": ["productID", "quantity"]
							}
						}
					}
				},
				"responses": {
					"201": {
						"description": "Item(s) added to Cart"
					},
					"400": {
						"description": "Bad request"
					}
				}
			}
		},

		"/api/cartItems/{id}": {
			"delete": {
				"tags": ["Cart"],
				"summary": "Delete from Cart",
				"description": "Remove product from cart",
				"security": [
					{
						"CookieAuth": []
					}
				],
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "integer"
						},
						"description": "Product ID"
					}
				],
				"responses": {
					"200": {
						"description": "Item deleted successfully"
					},
					"400": {
						"description": "Unable to delete item"
					}
				}
			}
		}
	}
}
