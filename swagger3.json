{
	"openapi": "3.0.4",
	"info": {
		"title": "e-comm apis",
		"description": "APIs for E-commerce web app",
		"version": "1.0.0"
	},
	"servers": [
		{
			"url": "http://localhost:3000/"
		}
	],
	"tags": [
		{
			"name": "Users",
			"description": "User login and register APIs"
		},
		{
			"name": "Products",
			"description": "Secure Products APIs endpoint for CRUD operations"
		}
	],
	"components": {
		"securitySchema": {
			"CookieAuth": {
				"type": "apiKey",
				"in": "cookie",
				"name": "jwtToken"
			}
		}
	},
	"paths": {
		"/api/users/login": {
			"post": {
				"tags": ["Users"],
				"summary": "login",
				"description": "User Login",
				"security": [],
				"requestBody": {
					"description": "User Credentials",
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"type": "object",
								"properties": {
									"email": {
										"type": "string"
									},
									"password": {
										"type": "string"
									}
								}
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "User logged in successfully"
					},
					"401": {
						"description": "Invalid email or password"
					}
				}
			}
		},
		"/api/users/register": {
			"post": {
				"tags": ["Users"],
				"summary": "Register",
				"description": "Register New User",
				"security": [],
				"requestBody": {
					"description": "User Information",
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"type": "object",
								"properties": {
									"name": {
										"type": "string"
									},
									"email": {
										"type": "string"
									},
									"password": {
										"type": "string"
									},
									"type": {
										"type": "string"
									}
								}
							}
						}
					}
				},
				"responses": {
					"201": {
						"description": "New user added successfully"
					}
				}
			}
		},
		"/api/products": {
			"post": {
				"tags": ["Products"],
				"summary": "Get Products List",
				"description": "Get Products List",
				"security": [
					{
						"CookieAuth": []
					}
				],
				"responses": {
					"200": {
						"description": "products listed below"
					},
					"404": {
						"description": "No products to list"
					}
				}
			}
		}
	}
}
